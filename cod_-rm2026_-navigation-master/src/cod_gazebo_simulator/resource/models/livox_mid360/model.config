<?xml version="1.0"?>
<model>
  <name>Livox MID-360</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>
  <author><name>Livox Debug Workspace</name></author>
  <description>Livox MID-360 LiDAR simulation model for Ignition Gazebo Fortress.
  Uses gpu_lidar sensor with 360-degree horizontal FOV, 10 Hz update rate.
  Mid-360 real specs: non-repetitive scan, FOV 360°×59°, range 40m@10% reflectivity.
  This simulation approximates with a single-ring 360° gpu_lidar scan.</description>
</model>
