<?xml version="1.0"?>
<!--
  COD RM2026 仿真机器人模型 — 占位模板
  ==========================================
  替换说明见 README.md

  关键接口名称 (保持这些名称不变):
  - base_link, livox_frame, livox_frame_joint
  - front_mid360_lidar, front_mid360_imu
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cod_robot">

  <!-- ===== 材料 ===== -->
  <material name="chassis_gray"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="wheel_black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="lidar_white"><color rgba="0.8 0.8 0.8 1.0"/></material>

  <!-- ===== base_link (底盘) ===== -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.40 0.35 0.20"/></geometry>
      <material name="chassis_gray"/>
    </visual>
    <collision>
      <geometry><box size="0.40 0.35 0.20"/></geometry>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <inertia ixx="0.3" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.4"/>
    </inertial>
  </link>

  <!-- ===== 麦克纳姆轮 x4 ===== -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel">
      <visual>
        <geometry><cylinder radius="0.06" length="0.03"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry><cylinder radius="0.06" length="0.03"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x} ${y} -0.08" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left"  x="0.18" y="0.18"/>
  <xacro:wheel name="front_right" x="0.18" y="-0.18"/>
  <xacro:wheel name="rear_left"   x="-0.18" y="0.18"/>
  <xacro:wheel name="rear_right"  x="-0.18" y="-0.18"/>

  <!-- ===== Livox MID-360 安装位 ===== -->
  <link name="livox_frame">
    <visual>
      <geometry><cylinder radius="0.05" length="0.06"/></geometry>
      <material name="lidar_white"/>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="livox_frame_joint" type="fixed">
    <parent link="base_link"/>
    <child link="livox_frame"/>
    <origin xyz="0.0 0.0 0.15" rpy="0 0.7854 0"/>   <!-- Pitch +45°: LiDAR前倾 -->
  </joint>

  <!-- ===== Gazebo 差速驱动插件 (sub cmd_vel → apply wheel velocity) ===== -->
  <gazebo>
    <plugin name="ignition::gazebo::systems::DiffDrive" filename="ignition-gazebo-diff-drive-system">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.36</wheel_separation>
      <wheel_radius>0.06</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <!-- ===== Gazebo JointState 发布 ===== -->
  <gazebo>
    <plugin name="ignition::gazebo::systems::JointStatePublisher"
            filename="ignition-gazebo-joint-state-publisher-system">
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- ===== Gazebo LiDAR 传感器 (MID-360 仿真) ===== -->
  <gazebo reference="livox_frame">
    <sensor name="front_mid360_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>40.0</max>
          <resolution>0.02</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

  <!-- ===== Gazebo IMU 传感器 ===== -->
  <gazebo reference="livox_frame">
    <sensor name="front_mid360_imu" type="imu">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>200</update_rate>
    </sensor>
  </gazebo>

</robot>
